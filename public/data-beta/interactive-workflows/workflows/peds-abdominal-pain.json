        "heading_path": [
          "Abdominal pain - acute",
          "Management",
          "Investigations"
        ],
        "dom_section_identifier": "rch-pic-acute-abdominal-pain-children-2024-section-0012",
        "position": 11,
        "paragraph_or_text_span": "Most children need no investigations Targeted investigation is directed by the likely differential diagnoses. These may include: Urine analysis (+/- culture +/- pregnancy test if indicated) LFTs eg for hepatitis Lipase eg for pancreatitis Venous blood gas for lactate/acidosis Blood glucose for DKA LFTs, lipase and UEC for abdominal injury FBE and CRP (+/- ESR) eg for inflammatory/infectious cause ",
        "normalized_span_fingerprint": "92b89c776b751c33d3a34e73e0a3a07d03c50c62152cdfc442c45c7853722c1b",
        "page_start": null,
        "page_end": null,
        "section_id": "rch-pic-acute-abdominal-pain-children-2024-section-0012"
      }
    },
    {
