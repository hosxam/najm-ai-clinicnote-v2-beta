    {
      "evidence_statement_id": "family-peds-abdominal--statement-00008",
      "source_id": "rch-pic-acute-abdominal-pain-children-2024",
      "official_source_url": "https://www.rch.org.au/clinicalguide/guideline_index/Abdominal_pain_-_acute/",
