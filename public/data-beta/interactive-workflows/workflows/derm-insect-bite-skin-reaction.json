        "dom_section_identifier": "nice-insect-bites-ng182-2020-section-0014",
        "position": 13,
        "paragraph_or_text_span": "For people with an insect bite or sting who have symptoms or signs of an infection, see the recommendations on choice of antibiotic in the NICE guideline on cellulitis and erysipelas . For a short explanation of why the committee made these recommendations, see the rationale section on treatment . For more details, see the summary of the evidence .",
        "normalized_span_fingerprint": "d9c7bd509d1b3600330140699da523861416555037cece72f9afb15a8d95991d",
        "page_start": null,
