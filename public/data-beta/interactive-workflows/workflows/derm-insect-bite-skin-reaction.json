        ],
        "dom_section_identifier": "nice-insect-bites-ng182-2020-section-0011",
        "position": 10,
        "paragraph_or_text_span": "Do not offer an antibiotic for an insect bite or sting in people who do not have symptoms or signs of an infection.",
        "normalized_span_fingerprint": "438aecfde8b3facb09b7e32522817a2c7260b504f363ba315549f00c13bca10f",
        "page_start": null,
