        ],
        "dom_section_identifier": "nice-insect-bites-ng182-2020-section-0023",
        "position": 22,
        "paragraph_or_text_span": "Erythema migrans is an expanding rash often seen in the early stage of Lyme disease, and can also (but less commonly) be caused by southern tick-associated rash illness. It usually becomes visible from 1 to 4 weeks (but can appear from 3 days to 3 months) after a tick bite and lasts for several weeks.",
        "normalized_span_fingerprint": "0942c4f2db6ff215caeb5833015ff3e08cb023445b0f3684648238f679d2fde1",
