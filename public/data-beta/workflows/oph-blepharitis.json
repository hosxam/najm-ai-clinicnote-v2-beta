30.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-swollen-eyelid-i2-blepharitis","heading":"Section 5.3 — blepharitis","locator":"pages 12–15","evidence_summary":"Supports blepharitis identity, watery or red eyes, gritty, burning, stinging, greasy, itchy, swollen or crusted eyelids, light sensitivity, eyelid observation, and clinician-documented eyelid-hygiene discussion."},{"section_id":"dha-swollen-eyelid-i2-referral","heading":"Section 9 — referral criteria","locator":"pages 22–23","evidence_summary":"Supports clinician-led referral, worsening, vision change, severe redness, severe pain, photophobia, spread, trauma, uncertain diagnosis, and refractory-symptom documentation without automatically concluding urgency."}]}],"evidence_links":[{"evidence_item_id":"oph-blepharitis--dha-swollen-eyelid-i2-blepharitis","source_id":"dha-swollen-eyelid-issue2-2024","source_section_id":"dha-swollen-eyelid-i2-blepharitis","direct_relationship":"Supports blepharitis identity, watery or red eyes, grittiness, burning or stinging, greasy or itchy eyelids, swelling, crusting, selected eyelid findings, and clinician-documented hygiene discussion.","paraphrased_evidence_summary":"Supports blepharitis identity, watery or red eyes, gritty, burning, stinging, greasy, itchy, swollen or crusted eyelids, light sensitivity, eyelid observation, and clinician-documented eyelid-hygiene discussion.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-blepharitis--dha-swollen-eyelid-i2-referral","source_id":"dha-swollen-eyelid-issue2-2024","source_section_id":"dha-swollen-eyelid-i2-referral","direct_relationship":"Supports clinician-led return, worsening, vision-change, severe-pain, and arranged follow-up documentation.","paraphrased_evidence_summary":"Supports clinician-led referral, worsening, vision change, severe redness, severe pain, photophobia, sprea