{"workflow_number":620,"workflow_id":"gi-rectal-bleeding-documentation","title":"Rectal bleeding documentation","specialty":"Gastroenterology outpatient","diagnosis":"Rectal bleeding documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"International evidence requires UAE gastroenterology, colorectal, hepatology, laboratory, endoscopy, referral, prescribing, screening, and local-pathway adaptation.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"bsg-acute-lower-gi-bleeding-2019","title":"Diagnosis and management of acute lower gastrointestinal bleeding: guidelines from the British Society of Gastroenterology","issuing_organisation":"British Society of Gastroenterology","official_url":"https://www.bsg.org.uk/getattachment/6d80aa64-9d11-4923-8789-a2e9b08502ef/gutjnl-2018-317807.pdf?lang=en-US","jurisdiction":"United Kingdom","sections":[{"section_id":"bsg-lgib-2019-scope-presentation","heading":"Scope of the guideline and background presentation description","locator":"PDF pages 2–3; lines 193–229","evidence_summary":"Defines acute adult hospital lower gastrointestinal bleeding as bright or dark red blood per rectum, clots per rectum, or blood mixed with stool, while warning that brisk bleeding should not automatically be ascribed to haemorrhoids."},{"section_id":"bsg-lgib-2019-initial-assessment","heading":"Management algorithm — initial assessment and Oakland variables","locator":"PDF page 4; lines 267–316","evidence_summary":"Supports routine observations, full history and examination including digital rectal examination, appropriate blood tests, heart rate, systolic blood pressure, haemoglobin, and previous lower-GI-bleeding admission context."},{"section_id":"bsg-lgib-2019-antithrombotic-context","heading":"Abstract and recommendations — anticoagulant and antiplatelet context","locator":"PDF pages 1–2; lines 58–60 and 110–145","evidence_summary":"Supports documenting whether anticoagulant or antiplatelet treatment is relevant to acute lower gastrointestinal bleeding; medicine interruption, reversal, and restart instructions are deliberately not mapped."},{"section_id":"bsg-lgib-2019-stability-followup","heading":"Recommendations 1–4 and risk assessment","locator":"PDF pages 1 and 4; lines 63–84 and 267–352","evidence_summary":"Supports clinician assessment of haemodynamic stability, major versus minor bleeding context, and qualified clinician-decided hospital or outpatient follow-up documentation without calculating a score or inserting disposition advice."}]}],"evidence_links":[{"evidence_item_id":"gi-rectal-bleeding-documentation--bsg-lgib-2019-scope-presentation","source_id":"bsg-acute-lower-gi-bleeding-2019","source_section_id":"bsg-lgib-2019-scope-presentation","direct_relationship":"The exact lower-GI bleeding section supports bleeding amount and character, stool association, onset, recurrence, associated symptoms, and presentation context without assigning source or severity.","paraphrased_evidence_summary":"Defines acute adult hospital lower gastrointestinal bleeding as bright or dark red blood per rectum, clots per rectum, or blood mixed with stool, while warning that brisk bleeding should not automatically be ascribed to haemorrhoids.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gi-rectal-bleeding-documentation--bsg-lgib-2019-initial-assessment","source_id":"bsg-acute-lower-gi-bleeding-2019","source_section_id":"bsg-lgib-2019-initial-assessment","direct_relationship":"The exact initial-assessment section supports clinician-entered vital signs, general and abdominal assessment, and concern documentation without calculating a score or asserting stability.","paraphrased_evidence_summary":"Supports routine observations, full history and examination including digital rectal examination, appropriate blood tests, heart rate, systolic blood pressure, haemoglobin, and previous lower-GI-bleeding admission context.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gi-rectal-bleeding-documentation--bsg-lgib-2019-antithrombotic-context","source_id":"bsg-acute-lower-gi-bleeding-2019","source_section_id":"bsg-lgib-2019-antithrombotic-context","direct_relationship":"The exact section supports recording anticoagulant or antiplatelet context and already reviewed results without changing medication.","paraphrased_evidence_summary":"Supports documenting whether anticoagulant or antiplatelet treatment is relevant to acute lower gastrointestinal bleeding; medicine interruption, reversal, and restart instructions are deliberately not mapped.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gi-rectal-bleeding-documentation--bsg-lgib-2019-stability-followup","source_id":"bsg-acute-lower-gi-bleeding-2019","source_section_id":"bsg-lgib-2019-stability-followup","direct_relationship":"The exact stability and follow-up section supports clinician-entered disposition, safety net, and follow-up documentation without assigning urgency.","paraphrased_evidence_summary":"Supports clinician assessment of haemodynamic stability, major versus minor bleeding context, and qualified clinician-decided hospital or outpatient follow-up documentation without calculating a score or inserting disposition advice.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true}],"unsupported_item_count":51,"safety_review_required_count":51,"unresolved_source_gaps":["Bleeding amount, haemodynamics, anaemia, antico