{"workflow_number":73,"workflow_id":"ophth-contact-lens-complaint","title":"Contact lens-related complaint","specialty":"Ophthalmology","diagnosis":"Contact lens complication","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"DHA guidance is directly applicable in Dubai; College guidance requires UAE clinician review and local referral pathways.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"college-optometrists-cl-infiltrative-keratitis-v9-2026","title":"Clinical Management Guideline: Keratitis, contact-lens-associated infiltrative","issuing_organisation":"The College of Optometrists","official_url":"https://www.college-optometrists.org/clinical-guidance/clinical-management-guidelines/keratitis_cl-associatedinfiltrative","jurisdiction":"United Kingdom specialty guidance","sections":[{"section_id":"college-cl-keratitis-v9-features","heading":"Clinical summary — presentation and differential safety","locator":"official page lines 306–314","evidence_summary":"Supports contact-lens use, usually unilateral redness, watering, foreign-body sensation, discomfort, photophobia, peripheral corneal opacity, and the need to distinguish sight-threatening microbial keratitis."},{"section_id":"college-cl-keratitis-v9-lens-care","heading":"Patient summary — lens cessation, hygiene, and wearing schedules","locator":"official page lines 315–345","evidence_summary":"Supports clinician-documented temporary lens cessation, hand and lens-case hygiene, avoidance of overnight wear, wearing-schedule review, and reassessment context."}]},{"source_resolves":true,"source_id":"college-optometrists-microbial-keratitis-v14-2024","title":"Clinical Management Guideline: Microbial keratitis (bacterial, fungal)","issuing_organisation":"The College of Optometrists","official_url":"https://www.college-optometrists.org/clinical-guidance/clinical-management-guidelines/microbialkeratitis_bacterial_fungal","jurisdiction":"United Kingdom specialty guidance","sections":[{"section_id":"college-microbial-keratitis-v14-features","heading":"Clinical and patient summaries — presentation","locator":"official page lines 306–319","evidence_summary":"Supports usually unilateral acute redness, moderate or severe pain, photophobia, watering, discharge, blurred vision, corneal opacity or ulcer, and contact-lens, injury, surgery, exposure, dry-eye, or immune-risk context."},{"section_id":"college-microbial-keratitis-v14-emergency","heading":"Patient summary — sight-threatening emergency and referral","locator":"official page lines 320–350","evidence_summary":"Identifies microbial keratitis as sight-threatening and supports urgent ophthalmology documentation; treatment specifics are not mapped."}]},{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]}],"evidence_links":[{"evidence_item_id":"ophth-contact-lens-complaint--dha-conjunctivitis-i2-red-flags","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-red-flags","direct_relationship":"Supports mapped vision, severe-pain, photophobia, corneal, redness, and contact-lens warning fields.","paraphrased_evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"ophth-contact-lens-complaint--dha-conjunctivitis-i2-diagnosis-history","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-diagnosis-history","direct_relationship":"Supports mapped contact-lens history, red eye, discharge, vision, corneal concern, lens fit or hygiene, and visual-acuity documentation.","paraphrased_evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved",