{"workflow_number":38,"workflow_id":"obgyn-early-pregnancy","title":"Early pregnancy symptoms","specialty":"OB/GYN","diagnosis":"Early pregnancy","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"No direct UAE applicability is established; UAE official sources were searched and this current NICE source requires UAE clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"nice-ectopic-miscarriage-ng126-2026","title":"Ectopic pregnancy and miscarriage: diagnosis and initial management","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/ng126","jurisdiction":"England, United Kingdom","sections":[{"section_id":"nice-ng126-scope-services","heading":"Overview and recommendations 1.3.1–1.3.4 — early pregnancy assessment services","locator":"overview and early-pregnancy-assessment-services chapter","evidence_summary":"Defines the up-to-13-week complication population and services offering specialist assessment, ultrasound, serum hCG review, and timely referral."},{"section_id":"nice-ng126-symptoms-assessment","heading":"Recommendations 1.4.1–1.4.12 — presentation, assessment and referral","locator":"symptoms-and-signs-of-ectopic-pregnancy-and-initial-assessment chapter","evidence_summary":"Lists pain, amenorrhoea, bleeding, gastrointestinal symptoms, dizziness or syncope, shoulder-tip pain, urinary symptoms, tenderness, haemodynamic signs, pregnancy testing, and escalation criteria."},{"section_id":"nice-ng126-ultrasound","heading":"Recommendations 1.5.1–1.7.6 — ultrasound for pregnancy location and viability","locator":"diagnosis-of-viable-intrauterine-pregnancy-and-of-tubal-ectopic-pregnancy chapter","evidence_summary":"Defines clinician-performed transvaginal or selected transabd