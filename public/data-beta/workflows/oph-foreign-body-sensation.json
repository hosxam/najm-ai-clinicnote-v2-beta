romise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]}],"evidence_links":[{"evidence_item_id":"oph-foreign-body-sensation--dha-conjunctivitis-i2-features","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-features","direct_relationship":"Supports foreign-body sensation, grittiness, red eye, watering, and mechanical or chemical context.","paraphrased_evidence_summary":"Describes unilateral or bilateral redness, watery, mucus or purulent discharge, crusting, itching, burning, grittiness, foreign-body sensation, contact spread, dry-eye symptoms, and mechanical or chemical insult context.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-foreign-body-sensation--dha-conjunctivitis-i2-red-flags","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-red-flags","direct_relationship":"Supports visual loss, photophobia, severe foreign-body sensation, and post-traumatic warning prompts.","paraphrased_evidence_summary":"Lists reduced visual acuit