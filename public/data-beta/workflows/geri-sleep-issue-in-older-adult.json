{"workflow_number":566,"workflow_id":"geri-sleep-issue-in-older-adult","title":"Sleep issue in older adult","specialty":"Geriatrics","diagnosis":"Sleep issue in older adult","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"UAE DHA evidence applies where cited; international evidence requires UAE geriatric, primary-care, social-care, sensory, nutrition, device, referral, and local policy adaptation.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-insomnia-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Insomnia","issuing_organisation":"Dubai Health Authority","official_url":"https://dha.gov.ae/uploads/032024/24%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Insomnia2024313354.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-insomnia-i2-history-daytime-function","heading":"Sections 5–7 — sleep history and daytime consequences","locator":"pages 7–12; extracted lines 79–180","evidence_summary":"Supports sleep initiation or maintenance difficulty, early waking, non-restorative sleep, adequate opportunity, fatigue, concentration, mood, irritability, daytime sleepiness, motivation, duration, stress, and functional impact."},{"section_id":"dha-insomnia-i2-red-flags-evaluation","heading":"Section 7 — red flags and evaluation","locator":"pages 12–14; extracted lines 182–212","evidence_summary":"Lists sleep attacks, apnoea or gasping, unstable cardiopulmonary disease, stroke, injury during sleep, sleepwalking, excessive daytime sleepiness, substance misuse, depression, anxiety, and significant functional impact; supports sleep-diary and targeted evaluation."},{"section_id":"dha-insomnia-i2-causes-investigations","heading":"Section 7 — substances, medicines, co