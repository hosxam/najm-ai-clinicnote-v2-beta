{"workflow_number":154,"workflow_id":"oph-dry-eye","title":"Dry eye","specialty":"Ophthalmology","diagnosis":"Dry eye","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"DHA is direct for Dubai telehealth red-eye triage. TFOS diagnostic methodology and test implementation require UAE eye-care clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-features","heading":"Sections 5.1–5.9 — infectious, allergic, and non-infectious features","locator":"pages 7–14","evidence_summary":"Describes unilateral or bilateral redness, watery, mucus or purulent discharge, crusting, itching, burning, grittiness, foreign-body sensation, contact spread, dry-eye symptoms, and mechanical or chemical insult context."},{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]},{"source_resolves":true,"source_id":"tfos-dews-ii-diagnostic-methodology-2017","title":"TFOS DEWS II Diagnostic Methodology report","issuing_organisation":"Tear Film & Ocular Surface Society Dry Eye Workshop II Diagnostic Methodology Subcommittee","official_url":"https://tfosdewsreport.org/report-diagnostic_methodology/131_36/en/","jurisdiction":"International specialty consensus report","sections":[{"section_id":"tfos-dews2-diagnostic-protocol","heading":"Clinical protocol for the dry-eye diagnostic test battery","locator":"Sections 8 and 8.1–8.4; official report lines 469–508","evidence_summary":"Supports dry-eye symptom screening, visual symptoms, tear-film tests, fluorescein or lissamine staining, and cornea, conjunctiva, or eyelid-margin observation without inferring diagnosis from symptoms alone."},{"section_id":"tfos-dews2-ocular-surface-eyelid","heading":"Ocular-surface damage and eyelid assessment","locator":"Sections 6.6 and 6.8; official report lines 327–365 and 402–463","evidence_summary":"Supports clinician-observed corneal, conjunctival, eyelid, and fluorescein-staining documentation in dry-eye evaluation."},{"section_id":"tfos-dews2-differential-contact-lens","heading":"Differential diagnosis, visual asthenopia, and contact lenses","locator":"Sections 9.8–9.11; official report lines 603–615","evidence_summary":"Supports screen-related visual discomfort, pain or photophobia as differential context, and contact-lens-associated dry-eye context without treatment instructions."}]}],"evidence_links":[{"evidence_item_id":"oph-dry-eye--tfos-dews2-diagnostic-protocol","source_id":"tfos-dews-ii-diagnostic-methodology-2017","source_section_id":"tfos-dews2-diagnostic-protocol","direct_relationship":"Supports mapped dry-eye identity, grittiness, visual fluctuation, and clinician-performed ocular-surface staining context without symptom-only diagnosis.","paraphrased_evidence_summary":"Supports dry-eye symptom screening, visual symptoms, tear-film tests, fluorescein or lissamine staining, and cornea, conjunctiva, or eyelid-margin observation without inferring diagnosis from symptoms alone.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-dry-eye--tfos-dews2-ocular-surface-eyelid","source_id":"tfos-dews-ii-diagnostic-methodology-2017","source_section_id":"tfos-dews2-ocular-surface-eyelid","direct_relationship":"Supports mapped corneal, conjunctival, eyelid, and fluorescein fields only when assessed.","paraphrased_evidence_summary":"Supports clinician-observed corneal, conjunctival, eyelid, and fluorescein-staining documentation in dry-eye evaluation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-dry-eye--tfos-dews2-differential-contact-lens","source_id":"tfos-dews-ii-diagnostic-methodology-2017","source_section_id":"tfos-dews2-differential-contact-lens","direct_relationship":"Supports mapped contact-lens and screen-related differential context; treatment is not mapped.","paraphrased_evidence_summary":"Supports screen-related visual discomfort, pain or photophobia as differential context, and contact-lens-associated dry-eye context without treatment instructions.","content_mapping_status":"reviewed_not_mapped_to_legacy_co