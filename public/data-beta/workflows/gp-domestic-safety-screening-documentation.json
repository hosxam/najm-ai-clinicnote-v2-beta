{"workflow_number":656,"workflow_id":"gp-domestic-safety-screening-documentation","title":"Domestic safety screening documentation","specialty":"General Medicine / GP","diagnosis":"Domestic safety screening documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"International WHO and UK emergency guidance requires explicit UAE legal, safeguarding, reporting, privacy, referral, and service-pathway review before clinical use.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"rcem-domestic-abuse-2015","title":"Management of Domestic Abuse","issuing_organisation":"Royal College of Emergency Medicine","official_url":"https://rcem.ac.uk/wp-content/uploads/2021/10/Management_of_Domestic_Abuse_March2015.pdf","jurisdiction":"United Kingdom emergency medicine; requires UAE legal and safeguarding adaptation","sections":[{"section_id":"rcem-domestic-abuse-2015-recognition","heading":"Summary and Recognition of Domestic Abuse","locator":"PDF pages 2–3","evidence_summary":"Supports recording clinician suspicion, confidential disclosure opportunity and direct enquiry only when clinically indicated; it does not support universal screening."}]},{"source_resolves":true,"source_id":"who-ipv-clinical-handbook-2014","title":"Health care for women subjected to intimate partner violence or sexual violence: a clinical handbook","issuing_organisation":"World Health Organization","official_url":"https://www.who.int/publications/i/item/WHO-RHR-14.26","jurisdiction":"International guidance requiring UAE legal, safeguarding and referral adaptation","sections":[{"section_id":"who-ipv-2014-first-line-support","heading":"First-line support and LIVES","locator":"Handbook pages 13–28 (PDF pages 21–36)","evidence_summary":"Supports listening, documenting needs and concerns, validating, assessing safety and recording support discussed without asserting abuse or imposing action."},{"section_id":"who-ipv-2014-documentation","heading":"Documenting partner violence","locator":"Handbook pages 12–13 (PDF pages 20–21)","evidence_summary":"Supports asking permission to document and recording complaints, symptoms, signs, injuries and relevant history in the person’s words without interpretation."},{"section_id":"who-ipv-2014-history-examination","heading":"History and physical examination after sexual violence","locator":"Handbook pages 40–46 (PDF pages 48–54)","evidence_summary":"Supports respectful, consent-based history and head-to-toe examination documentation only when relevant and performed; sexual-assault care is not generalized to every domestic-violence presentation."}]}],"evidence_links":[{"evidence_item_id":"gp-domestic-safety-screening-documentation--who-ipv-2014-first-line-support","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-first-line-support","direct_relationship":"The exact WHO first-line-support section supports private, patient-led documentation of immediate emotional, physical, safety, and support needs without inferring violence, coercing disclosure, or generating an action.","paraphrased_evidence_summary":"Supports listening, documenting needs and concerns, validating, assessing safety and recording support discussed without asserting abuse or imposing action.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gp-domestic-safety-screening-documentation--who-ipv-2014-history-examination","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-history-examination","direct_relationship":"The exact history and examination section supports clinician-entered history and examination only when disclosure and consent make it appropriate; no intimate examination, assault, or injury finding is inferred.","paraphrased_evidence_summary":"Supports respectful, consent-based history and head-to-toe examination documentation only when relevant and performed; sexual-assault care is not generalized to every domestic-violence presentation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gp-domestic-safety-screening-documentation--rcem-domestic-abuse-2015-recognition","source_id":"rcem-domestic-abuse-2015","source_section_id":"rcem-domestic-abuse-2015-recognition","direct_relationship":"The exact recognition section supports clinician awareness of immediate safety, injury, children, vulnerability, and escalation concerns without treating a generic screening field as a positive finding.","paraphrased_evidence_summary":"Supports recording clinician suspicion, confidential disclosure opportunity and direct enquiry only when clinically indicated; it does not support universal screening.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"gp-domestic-safety-screening-documentation--who-ipv-2014-documentation","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-documentation","direct_relationship":"The exact documentation section supports accurate clinician-entered records, available findings, patient words, consent-sensitive communication, safety discussion, and follow-up without automatic referral or reporting.","paraphrased_evidence_summary":"Supports asking permission to document and recording complaints, symptoms, signs, injuries and relevant history in the person’s words without interpretation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true}],"unsupported_item_count":51,"safety_review_required_count":51,"unresolved_source_gaps":["