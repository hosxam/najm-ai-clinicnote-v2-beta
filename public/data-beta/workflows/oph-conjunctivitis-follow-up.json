{"workflow_number":997,"workflow_id":"oph-conjunctivitis-follow-up","title":"Conjunctivitis follow-up","specialty":"Ophthalmology","diagnosis":"Conjunctivitis follow-up","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"DHA is explicitly applicable to Dubai virtual conjunctivitis assessment.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"DHA is explicitly applicable to Dubai virtual conjunctivitis assessment."}],"source_references":[{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-features","heading":"Sections 5.1–5.9 — infectious, allergic, and non-infectious features","locator":"pages 7–14","evidence_summary":"Describes unilateral or bilateral redness, watery, mucus or purulent discharge, crusting, itching, burning, grittiness, foreign-body sensation, contact spread, dry-eye symptoms, and mechanical or chemical insult context."},{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photopho