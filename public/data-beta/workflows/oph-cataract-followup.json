{"workflow_number":175,"workflow_id":"oph-cataract-followup","title":"Cataract follow-up","specialty":"Ophthalmology","diagnosis":"Cataract follow-up","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"No exact UAE cataract follow-up guideline was identified. DHA red-eye warnings are direct for Dubai telehealth; NICE cataract pathways require UAE clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]},{"source_resolves":true,"source_id":"nice-cataracts-adults-ng77-2025","title":"Cataracts in adults: management","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/ng77/chapter/recommendations","jurisdiction":"England and Wales clinical guidance","sections":[{"section_id":"nice-ng77-cataract-information-function-referral","heading":"Recommendations 1.1.1–1.2.2 — cataract information, visual function, quality of life, and referral discussion","locator":"recommendations 1.1.1–1.2.2; official page lines 43–154","evidence_summary":"Supports cataract identity, how cataract affects vision and quality of life, whether one or both eyes are affected, tailored information, and a preference-sensitive clinician discussion about cataract surgery without making a referral decision automatically."},{"section_id":"nice-ng77-cataract-postoperative-review","heading":"Recommendations 1.1.5–1.1.6 and 1.9.1–1.9.3 — postoperative information and assessment","locator":"recommendations 1.1.5–1.1.6 and 1.9.1–1.9.3; official page lines 101–136 and 473–489","evidence_summary":"Supports documenting expected visual changes, possible complication symptoms, activity or driving restrictions, contact arrangements, next appointment, vision change, spectacles, second-eye discussion, visual function, quality of life, and postoperative review processes without mapping medicines, doses, or autonomous urgency."}]}],"evidence_links":[{"evidence_item_id":"oph-cataract-followup--nice-ng77-cataract-information-function-referral","source_id":"nice-cataracts-adults-ng77-2025","source_section_id":"nice-ng77-cataract-information-function-referral","direct_relationship":"Supports cataract identity, reduced vision, functional or quality-of-life impact, laterality discussion, and clinician-documented cataract or surgery discussion.","paraphrased_evidence_summary":"Supports cataract identity, how cataract affects vision and quality of life, whether one or both eyes are affected, tailored information, and a preference-sensitive clinician discussion about cataract surgery without making a referral decision automatically.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-cataract-followup--nice-ng77-cataract-postoperative-review","source_id":"nice-cataracts-adults-ng77-2025","source_section_id":"nice-ng77-cataract-postoperative-review","direct_relationship":"Supports clinician-documented visual change, activity or driving discussion, spectacles, questions, next appointment, visual-function review, and follow-up without medicine details.","paraphrased_evidence_summary":"Supports documenting expected visual changes, possible complication symptoms, activity or driving restrictions, contact arrangements, next appointment, vision change, spectacles, second-eye discussion, visual function, quality of life, and postoperative review processes without mapping medicines, doses, or autonomous urgency.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-cataract-followup--dha-conjunctivitis-i2-red-flags","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-red-flags","direct_relationship":"Supports pain, red eye, sudden or reduced vision, and photophobia warning prompts in a broad red-eye differential.","paraphrased_evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-cataract-followup--dha-conjunctivitis-i2-diagnosis-history","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-diagnosis-history","direct_relationship":"Supports visual review and assessed red-eye history without inferring a cataract complication.","paraphrased_evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-cataract-followup--dha-conjunctivitis-i2-management-referral","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-management-referral","direct_relationship":"Supports clinician-documented earlier review when pain, visual change, or red-eye concerns worsen without automatic referral.","paraphrased_evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true}],"unsupported_item_count":72,"safety_review_required_count":72,"unresolved_source_gaps":["Blurred or cloudy vision wording, glare, halos, night-driving difficulty, lens opacity, red reflex, eye pressure, discharge, fixed three-to-six-month review, and the combined history draft remain unsupported