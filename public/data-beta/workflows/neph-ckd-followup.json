{"workflow_number":148,"workflow_id":"neph-ckd-followup","title":"CKD follow-up","specialty":"Urology / Nephrology","diagnosis":"CKD follow-up documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"No exact current UAE CKD follow-up guideline was identified. KDIGO is international and local referral or monitoring implementation requires UAE clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"kdigo-ckd-evaluation-management-2024","title":"KDIGO 2024 Clinical Practice Guideline for the Evaluation and Management of Chronic Kidney Disease","issuing_organisation":"Kidney Disease: Improving Global Outcomes","official_url":"https://kdigo.org/wp-content/uploads/2024/03/KDIGO-2024-CKD-Guideline.pdf","jurisdiction":"International specialty guidance","sections":[{"section_id":"kdigo-ckd-2024-detection-chronicity","heading":"Detection of CKD and evaluation of chronicity","locator":"Practice Points 1.1.1.1–1.1.1.2 and 1.1.3.1–1.1.3.2; summary PDF pages 34 and 54–57","evidence_summary":"Supports GFR and urine-albumin testing, repeat confirmation, prior GFR or albuminuria trends, imaging, history, and the minimum chronicity context without diagnosing CKD from one result."},{"section_id":"kdigo-ckd-2024-cause-kidney-context","heading":"Evaluation of cause and kidney-function context","locator":"Practice Point 1.1.4.1, Figure 8, Table 6, and Practice Point 1.2.1.1; summary PDF pages 34–35 and 61","evidence_summary":"Supports careful medical, family, medicine, urinary, systemic, examination, urinalysis, ACR, electrolyte, and imaging context in clinician-led CKD evaluation."},{"section_id":"kdigo-ckd-2024-monitoring-progression","heading":"Monitoring GFR and albuminuria in CKD","locator":"Practice Points 2.1.1–2.1.5; summary PDF pages 40 and 81–82","evidence_summary":"Supports clinician-arranged GFR and albuminuria monitoring and evaluation of a greater-than-20-percent eGFR change or ACR doubling without mapping fixed legacy intervals."},{"section_id":"kdigo-ckd-2024-medication-stewardship","heading":"Polypharmacy and drug stewardship","locator":"Practice Point 4.3.1 and Figure 46; summary PDF pages 50 and 135–137","evidence_summary":"Supports periodic medication review, accurate medication lists, adherence, continued indication, interaction, monitoring, reconciliation, and nephrotoxic-medicine context without treatment changes or doses."},{"section_id":"kdigo-ckd-2024-referral","heading":"Referral to specialist kidney care services","locator":"Practice Point 5.1.1 and Figure 48; summary PDF pages 51 and 140–141","evidence_summary":"Supports clinician-led referral documentation for qualified sustained GFR decline, significant albuminuria with haematuria, refractory hypertension, persistent potassium abnormalities, and other listed circumstances."}]}],"evidence_links":[{"evidence_item_id":"neph-ckd-followup--kdigo-ckd-2024-detection-chronicity","source_id":"kdigo-ckd-evaluation-management-2024","source_section_id":"kdigo-ckd-2024-detection-chronicity","direct_relationship":"Supports mapped CKD, renal-function, eGFR, prior-trend, and confirmation context without diagnosing CKD from one result.","paraphrased_evidence_summary":"Supports GFR and urine-albumin testing, repeat confirmation, prior GFR or albuminuria trends, imaging, history, and the minimum chronicity context without diagnosing CKD from one result.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"neph-ckd-followup--kdigo-ckd-2024-cause-kidney-context","source_id":"kdigo-ckd-evaluation-management-2024","source_section_id":"kdigo-ckd-2024-cause-kidney-context","direct_relationship":"Supports mapped urinary, medicine, nephrotoxic, electrolyte, urinalysis, and clinical-context fields.","paraphrased_evidence_summary":"Supports careful medical, family, medicine, urinary, systemic, examination, urinalysis, ACR, electrolyte, and imaging context in clinician-led CKD evaluation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"neph-ckd-followup--kdigo-ckd-2024-monitoring-progression","source_id":"kdigo-ckd-evaluation-management-2024","source_section_id":"kdigo-ckd-2024-monitoring-progression","direct_relationship":"Supports mapped GFR and ACR trend review and clinician-arranged reassessment after material change without fixed legacy intervals.","paraphrased_evidence_summary":"Supports clinician-arranged GFR and albuminuria monitoring and evaluation of a greater-than-20-percent eGFR change or ACR doubling without mapping fixed legacy intervals.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"neph-ckd-followup--kdigo-ckd-2024-medication-stewardship","source_id":"kdigo-ckd-evaluation-management-2024","source_section_id":"kdigo-ckd-2024-medication-stewardship","direct_relationship":"Supports mapped medication-list, adherence, review, monitoring, interaction, and nephrotoxic-context fields without treatment changes.","paraphrased_evidence_summary":"Supports periodic medication review, accurate medication lists, adherence, continued indication, interaction, monitoring, reconciliation, and nephrotoxic-medicine context without treatment changes or doses.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"neph-ckd-followup--kdigo-ckd-2024-referral","source_id":"kdigo-ckd-evaluation-management-2024","source_section_id":"kdigo-ckd-2024-referral","direct_relationship":"Supports mapped refractory-hypertension, po