{"workflow_number":143,"workflow_id":"uro-luts-bph","title":"LUTS/BPH","specialty":"Urology / Nephrology","diagnosis":"LUTS/BPH documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"No exact UAE LUTS guideline was identified. NICE service, PSA, referral, and treatment pathways require UAE clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"nice-luts-men-cg97-2015","title":"Lower urinary tract symptoms in men: management","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/cg97/chapter/Recommendations","jurisdiction":"England, United Kingdom","sections":[{"section_id":"nice-cg97-luts-initial-assessment","heading":"Initial assessment","locator":"Recommendations 1.1.1–1.1.15","evidence_summary":"Supports symptom and medicine history, abdominal and genital examination, digital rectal examination, frequency-volume context, urinalysis, qualified PSA discussion, qualified creatinine, conservative-advice documentation, and referral criteria."},{"section_id":"nice-cg97-luts-specialist-assessment","heading":"Specialist assessment","locator":"Recommendations 1.2.1–1.2.7","evidence_summary":"Supports specialist history and examination, urinary flow, post-void residual, and recommendation-qualified imaging or cystoscopy context."},{"section_id":"nice-cg97-urinary-retention","heading":"Treating urinary retention","locator":"Recommendations 1.7.1–1.7.10","evidence_summary":"Supports acute or chronic urinary-retention context, palpable or percussable bladder, residual volume, creatinine, qualified imaging, and clinician-led follow-up or referral; catheter and medicine instructions are not mapped."}]}],"evidence_links":[{"evidence_item_id":"uro-luts-bph--nice-cg97-luts-initial-assessment","source_id":"nice-luts-men-cg97-2015","source_section_id":"nice-cg97-luts-initial-assessment","direct_relationship":"Supports mapped adult male LUTS history, abdominal or bladder or rectal examination, urinalysis, qualified PSA or creatinine, conservative-advice, referral, follow-up, and combined-history fields.","paraphrased_evidence_summary":"Supports symptom and medicine history, abdominal and genital examination, digital rectal examination, frequency-volume context, urinalysis, qualified PSA discussion, qualified creatinine, conservative-advice documentation, and referral criteria.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"uro-luts-bph--nice-cg97-luts-specialist-assessment","source_id":"nice-luts-men-cg97-2015","source_section_id":"nice-cg97-luts-specialist-assessment","direct_relationship":"Supports mapped urinary-flow and post-void-residual documentation in specialist assessment.","paraphrased_evidence_summary":"Supports specialist history and examination, urinary flow, post-void residual, and recommendation-qualified imaging or cystoscopy context.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"uro-luts-bph--nice-cg97-urinary-retention","source_id":"nice-luts-men-cg97-2015","source_section_id":"nice-cg97-urinary-retention","direct_relationship":"Supports mapped acute-retention prompts without mapping catheter, medicine, or surgery instructions.","paraphrased_evidence_summary":"Supports acute or chronic urinary-retention context, palpable or percussable bladder, residual volume, creatinine, qualified imaging, and clinician-led follow-up or referral; catheter and medicine instructions are not mapped.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":