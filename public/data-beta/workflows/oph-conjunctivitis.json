{"workflow_number":153,"workflow_id":"oph-conjunctivitis","title":"Conjunctivitis","specialty":"Ophthalmology","diagnosis":"Conjunctivitis","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"Verified for DHA-licensed telehealth in Dubai, United Arab Emirates.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-features","heading":"Sections 5.1–5.9 — infectious, allergic, and non-infectious features","locator":"pages 7–14","evidence_summary":"Describes unilateral or bilateral redness, watery, mucus or purulent discharge, crusting, itching, burning, grittiness, foreign-body sensation, contact spread, dry-eye symptoms, and mechanical or chemical insult context."},{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]}],"evidence_links":[{"evidence_item_id":"oph-conjunctivitis--dha-conjunctivitis-i2-features","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-features","direct_relationship":"Supports mapped conjunctivitis, redness, discharge, crusting, itch, swelling, exposure, contact-lens, and duration fields.","paraphrased_evidence_summary":"Describes unilateral or bilateral redness, watery, mucus or purulent discharge, crusting, itching, burning, grittiness, foreign-body sensation, contact spread, dry-eye symptoms, and mechanical or chemical insult context.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-conjunctivitis--dha-conjunctivitis-i2-red-flags","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-red-flags","direct_relationship":"Supports mapped vision, severe-pain, photophobia, trauma, contact-lens, and corneal warning fields as prompts only.","paraphrased_evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-conjunctivitis--dha-conjunctivitis-i2-diagnosis-history","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-diagnosis-history","direct_relationship":"Supports mapped clinician-assessed visual-acuity, discharge, eyelid, conjunctival, corneal, pupil, history-draft, and qualified swab fields.","paraphrased_evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"oph-conjunctivitis--dha-conjunctivitis-i2-management-referral","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-management-referral","direct_relationship":"Supports mapped eye-hygiene, contact-lens, medicine-plan, return, response-review, and follow-up documentation without doses.","paraphrased_evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true}],"unsupported_item_count":78,"safety_review_required_count":78,"unresolved_source_gaps":["The broad alias eye infection, external-eye examination, fluorescein, eye movements, red reflex, fundoscopy, visual fields, general patient-question field, and autonomous interpretation remain unsupported.","Conjunctivitis subtype, infection, keratitis, trauma, or corneal disease must not be inferred from individual symptoms.","Medication choice or dose, referral