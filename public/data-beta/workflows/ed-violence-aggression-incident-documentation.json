{"workflow_number":433,"workflow_id":"ed-violence-aggression-incident-documentation","title":"ED violence/aggression incident documentation","specialty":"Emergency Medicine documentation-only","diagnosis":"ED violence/aggression incident documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"Documentation principles transfer, but UAE consent, capacity, restraint, police, security, mental-health, safeguarding and incident-reporting law and policy govern.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"nice-violence-aggression-ng10-2015","title":"Violence and aggression: short-term management in mental health, health and community settings","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/ng10/chapter/Recommendations","jurisdiction":"England, United Kingdom","sections":[{"section_id":"nice-ng10-risk-deescalation","heading":"Recommendations 1.2.8–1.2.14 and 1.3.12–1.3.20 — risk assessment and de-escalation","locator":"recommendations 1.2.8–1.2.14 and 1.3.12–1.3.20","evidence_summary":"Supports objective multidisciplinary risk assessment, prior incident and trigger context, service-user involvement, previously effective de-escalation and transfer of an existing risk assessment."},{"section_id":"nice-ng10-incident-monitoring","heading":"Recommendations 1.4.23–1.4.45 — restrictive-intervention safety and monitoring","locator":"recommendations 1.4.23–1.4.45","evidence_summary":"Supports documenting airway, breathing, circulation, vital signs, physical and psychological monitoring and clinician review only when a restrictive intervention actually occurred. Medicine instructions and doses are excluded."},{"section_id":"nice-ng10-post-incident-review","heading":"Recommendations 1.4