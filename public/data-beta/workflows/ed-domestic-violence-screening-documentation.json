{"workflow_number":393,"workflow_id":"ed-domestic-violence-screening-documentation","title":"ED domestic violence screening documentation","specialty":"Emergency Medicine documentation-only","diagnosis":"ED domestic violence screening documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"Core survivor-centred documentation principles transfer, but UAE consent, confidentiality, mandatory reporting, police, safeguarding, social support and language pathways govern.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"rcem-domestic-abuse-2015","title":"Management of Domestic Abuse","issuing_organisation":"Royal College of Emergency Medicine","official_url":"https://rcem.ac.uk/wp-content/uploads/2021/10/Management_of_Domestic_Abuse_March2015.pdf","jurisdiction":"United Kingdom emergency medicine; requires UAE legal and safeguarding adaptation","sections":[{"section_id":"rcem-domestic-abuse-2015-recognition","heading":"Summary and Recognition of Domestic Abuse","locator":"PDF pages 2–3","evidence_summary":"Supports recording clinician suspicion, confidential disclosure opportunity and direct enquiry only when clinically indicated; it does not support universal screening."},{"section_id":"rcem-domestic-abuse-2015-disclosure-record","heading":"Disclosure, injury records, child welfare and support","locator":"PDF pages 3–5","evidence_summary":"Supports recording disclosure, injuries, child-welfare concerns, and offered contact or support only when actually discussed or completed."}]},{"source_resolves":true,"source_id":"who-ipv-clinical-handbook-2014","title":"Health care for women subjected to intimate partner violence or sexual violence: a clinical handbook","issuing_organisation":"World Health Organization","official_url":"https://www.who.int/publications/i/item/WHO-RHR-14.26","jurisdiction":"International guidance requiring UAE legal, safeguarding and referral adaptation","sections":[{"section_id":"who-ipv-2014-first-line-support","heading":"First-line support and LIVES","locator":"Handbook pages 13–28 (PDF pages 21–36)","evidence_summary":"Supports listening, documenting needs and concerns, validating, assessing safety and recording support discussed without asserting abuse or imposing action."},{"section_id":"who-ipv-2014-documentation","heading":"Documenting partner violence","locator":"Handbook pages 12–13 (PDF pages 20–21)","evidence_summary":"Supports asking permission to document and recording complaints, symptoms, signs, injuries and relevant history in the person’s words without interpretation."},{"section_id":"who-ipv-2014-history-examination","heading":"History and physical examination after sexual violence","locator":"Handbook pages 40–46 (PDF pages 48–54)","evidence_summary":"Supports respectful, consent-based history and head-to-toe examination documentation only when relevant and performed; sexual-assault care is not generalized to every domestic-violence presentation."}]}],"evidence_links":[{"evidence_item_id":"ed-domestic-violence-screening-documentation--who-ipv-2014-first-line-support","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-first-line-support","direct_relationship":"The exact WHO first-line-support section supports documenting the person’s concerns or goals, associated needs, relevant negatives and clinician-assessed safety context only when discussed; it does not assert violence or mandate action.","paraphrased_evidence_summary":"Supports listening, documenting needs and concerns, validating, assessing safety and recording support discussed without asserting abuse or imposing action.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"ed-domestic-violence-screening-documentation--who-ipv-2014-documentation","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-documentation","direct_relationship":"The exact WHO documentation section supports a consent-based record of complaints, symptoms, signs or injuries, completed risk discussion and clinician-entered plan only when actually discussed.","paraphrased_evidence_summary":"Supports asking permission to document and recording complaints, symptoms, signs, injuries and relevant history in the person’s words without interpretation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"ed-domestic-violence-screening-documentation--who-ipv-2014-history-examination","source_id":"who-ipv-clinical-handbook-2014","source_section_id":"who-ipv-2014-history-examination","direct_relationship":"The exact history and examination section supports recording focused examination and general appearance only when consented to and performed; it does not mandate a sexual-assault examination.","paraphrased_evidence_summary":"Supports respectful, consent-based history and head-to-toe examination documentation only when relevant and performed; sexual-assault care is not generalized to every domestic-violence presentation.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"ed-domestic-violence-screening-documentation--rcem-domestic-abuse-2015-disclosure-record","source_id":"rcem-domestic-abuse-2015","source_section_id":"rcem-domestic-abuse-2015-disclosure-record","direct_relationship":"The exact RCEM disclosure section supports recording safeguarding concern, specialist discussion and handover or follow-up only when disclosure occurred and actions were completed.","paraphrased_evidence_summary":"Supports recording disclosure, injuries, child-welfare concerns, and offered contact or support only when actually discussed or completed.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"ed-domestic-violence-screening-documentation--rcem-domestic-abuse-2015-recognition","source_id":"rcem-domestic-abuse-2015","source_section_id":"rcem-domestic-abuse-2015-recognition","direct_relationship":"Recognition and clinically indicated direct enquiry were reviewed; the source does not support universal screening.","paraphrased_evidence_summary":"Supports recording clinician suspicion, confidential disclosure opportunity and direct enquiry only when clinically indicated; it does not support universal screening.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true}],"unsupported_item_count":52,"safety_review_required_count":52,"unresolved_source_gaps":["Population beyond adult women, safe interpreter use, perpetrator relationship, children/dependants, immediate danger, coercive control, sexual violence, strangulation, pregnancy, injury details, forensic examination, reporting law and local referral remain unsupported.","Any legacy item not explicitly mapped to an exact section remains unsupported pending qualified clinician review.","No mapping authorises an automatic diagnosis, differential, investigation, management decision, medicine, dose, procedure, referral, urgency conclusion, discharge decision, or patient instruction.","All prior supported legacy-item mappings were removed because canonical item-level applicability and workflow-specific rationale were not present in explicit repository records."],"clinical_review_required":true,"active_clinical_approval":false,"clinician_review_status":"not_reviewed","items":[{"item_id":"ed-domestic-violence-screening-documentation--workflow-presentation--chief-complaint","section_id":"workflow_identity","section_la