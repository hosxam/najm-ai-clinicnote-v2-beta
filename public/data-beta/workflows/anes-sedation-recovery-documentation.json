{"workflow_number":250,"workflow_id":"anes-sedation-recovery-documentation","title":"Sedation recovery documentation","specialty":"Anesthesia / Perioperative Medicine","diagnosis":"Sedation recovery documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"International ASA and BSG evidence requires UAE sedation credentialing, monitoring, rescue, discharge, and facility-policy adaptation.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"asa-postanesthesia-care-2024","title":"Standards for Postanesthesia Care","issuing_organisation":"American Society of Anesthesiologists","official_url":"https://www.asahq.org/standards-and-practice-parameters/standards-for-postanesthesia-care","jurisdiction":"United States specialty standard","sections":[{"section_id":"asa-postanesthesia-monitoring-record","heading":"Standard III — continual evaluation and recovery record","locator":"official standard, Standard III","evidence_summary":"Supports documented oxygenation, ventilation, circulation, consciousness, temperature, pain or other recovery observations, and use of a recovery score where appropriate."},{"section_id":"asa-postanesthesia-discharge-criteria","heading":"Standards IV–V — discharge responsibility and criteria","locator":"official standard, Standards IV–V","evidence_summary":"Supports qualified discharge responsibility and institution-approved discharge criteria as recorded decisions, not automatic clearance."}]},{"source_resolves":true,"source_id":"bsg-endoscopy-sedation-2023","title":"British Society of Gastroenterology guidelines on sedation in gastrointestinal endoscopy","issuing_organisation":"British Society of Gastroenterology","official_url":"https://www.bsg.org.uk/getattachment/dfb6942c-3482-49fe-afc0-1df88891f7fc/BSG-Guidelines-on-Sedation-in-Gastrointestinal-Endoscopy-2023.pdf","jurisdiction":"United Kingdom","sections":[{"section_id":"bsg-endoscopy-sedation-2023-monitoring-recovery","heading":"Recommendations 16–17 — monitoring and complete recovery","locator":"PDF pages 12–13; lines 1232–1288","evidence_summary":"Supports documenting recovery progress, baseline consciousness or function, vital monitoring, complications during recovery, information exchange, follow-up planning, and discharge advice."}]}],"evidence_links":[{"evidence_item_id":"anes-sedation-recovery-documentation--asa-postanesthesia-monitoring-record","source_id":"asa-postanesthesia-care-2024","source_section_id":"asa-postanesthesia-monitoring-record","direct_relationship":"The ASA standard supports a documented recovery record and ongoing evaluation of oxygenation, ventilation, circulation, consciousness, temperature, pain, nausea, hydration, and other observed domains without auto-populating findings.","paraphrased_evidence_summary":"Supports documented oxygenation, ventilation, circulation, consciousness, temperature, pain or other recovery observations, and use of a recovery score where appropriate.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","candidate_status":"review_only_not_approved","source_resolves":true},{"evidence_item_id":"anes-sedation-recovery-documentation--bsg-endoscopy-sedation-2023-monitoring-recovery","source_id":"bsg-endoscopy-sedation-2023","source_section_id":"bsg-endoscopy-sedation-2023-monitoring-recovery","direct_relationship":"The BSG section supports monitoring until return to baseline and documented recovery only in gastrointestinal endoscopy sedation; it is not generalized to all sedation procedures.","paraphrased_evidence_summary":"Supports documenting recovery progress, baseline consciousness or function, vital monitoring, complications during recovery, information exchange, follow-up planning, and discharge advice.","content_mapping_status":"reviewed_not_mapped_to_legacy_content","ca