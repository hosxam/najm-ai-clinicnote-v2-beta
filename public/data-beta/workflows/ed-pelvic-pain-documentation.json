{"workflow_number":415,"workflow_id":"ed-pelvic-pain-documentation","title":"ED pelvic pain documentation","specialty":"Emergency Medicine documentation-only","diagnosis":"ED pelvic pain documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"Clinical domains transfer, but UAE pregnancy, gynecology, consent, imaging, laboratory, safeguarding and referral pathways govern.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"nice-ectopic-miscarriage-ng126-2026","title":"Ectopic pregnancy and miscarriage: diagnosis and initial management","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/ng126","jurisdiction":"England, United Kingdom","sections":[{"section_id":"nice-ng126-symptoms-assessment","heading":"Recommendations 1.4.1–1.4.12 — presentation, assessment and referral","locator":"symptoms-and-signs-of-ectopic-pregnancy-and-initial-assessment chapter","evidence_summary":"Lists pain, amenorrhoea, bleeding, gastrointestinal symptoms, dizziness or syncope, shoulder-tip pain, urinary symptoms, tenderness, haemodynamic signs, pregnancy testing, and escalation criteria."},{"section_id":"nice-ng126-ultrasound","heading":"Recommendations 1.5.1–1.7.6 — ultrasound for pregnancy location and viability","locator":"diagnosis-of-viable-intrauterine-pregnancy-and-of-tubal-ectopic-pregnancy chapter","evidence_summary":"Defines clinician-performed transvaginal or selected transabdominal ultrasound and cautions against overinterpreting one early scan or LMP alone."}]},{"source_resolves":true,"source_id":"rcog-chronic-pelvic-pain-gtg41-2012","title":"The Initial Management of Chronic Pelvic Pain — Green-top Guideline No. 41","issuing_organisation":"Royal College of Obstetricians and Gynaecologists"