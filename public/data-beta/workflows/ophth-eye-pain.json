{"workflow_number":70,"workflow_id":"ophth-eye-pain","title":"Eye pain","specialty":"Ophthalmology","diagnosis":"Keratitis / corneal abrasion","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"DHA red-eye guidance is directly applicable in Dubai; international eye guidance requires UAE clinician review and local referral pathways.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"college-optometrists-corneal-abrasion-v15-2025","title":"Clinical Management Guideline: Corneal abrasion","issuing_organisation":"The College of Optometrists","official_url":"https://www.college-optometrists.org/clinical-guidance/clinical-management-guidelines/cornealabrasion","jurisdiction":"United Kingdom specialty guidance","sections":[{"section_id":"college-corneal-abrasion-v15-features","heading":"Clinical information and patient summary — causes and symptoms","locator":"official page lines 306–315","evidence_summary":"Supports minor-injury, foreign-body and contact-lens context plus pain, blepharospasm, blurred vision, photophobia, watering, and redness."},{"section_id":"college-corneal-abrasion-v15-assessment-referral","heading":"Patient summary — assessment and referral","locator":"official page lines 316–345","evidence_summary":"Supports clinician assessment of the involved area, fluorescein documentation, and referral when injury is deeper, contaminated, or possibly infected; medicine details are not mapped."}]},{"source_resolves":true,"source_id":"college-optometrists-eye-referral-annex4-current","title":"Guidance for Professional Practice Annex 4: Urgency of referrals table","issuing_organisation":"The College of Optometrists","official_url":"https://www.college-optometrists.org/clinical-guidance/guidance/guidance-annexes/annex-4-urgency-of-referrals-table","jurisdiction":"United Kingdom specialty guidance","sections":[{"section_id":"college-eye-referral-annex4-anterior-trauma","heading":"Annex 4 — anterior eye and traumatic red-eye referrals","locator":"official page lines 240–288","evidence_summary":"Lists severe chemical burns, penetrating injuries, hyphema, embedded corneal foreign body, corneal or lid laceration, blunt trauma, severe abrasion, infective keratitis, and other urgent anterior-eye presentations."},{"section_id":"college-eye-referral-annex4-vision-pain","heading":"Annex 4 — visual loss and other urgent presentations","locator":"official page lines 289–336","evidence_summary":"Lists sudden visual loss, sudden vision change, flashes or floaters with retinal signs, retinal detachment, acute diplopia, severe eye pain with nausea or vomiting, pain on eye movement, and new pupil defects."}]},{"source_resolves":true,"source_id":"college-optometrists-microbial-keratitis-v14-2024","title":"Clinical Management Guideline: Microbial keratitis (bacterial, fungal)","issuing_organisation":"The College of Optometrists","official_url":"https://www.college-optometrists.org/clinical-guidance/clinical-management-guidelines/microbialkeratitis_bacterial_fungal","jurisdiction":"United Kingdom specialty guidance","sections":[{"section_id":"college-microbial-keratitis-v14-features","heading":"Clinical and patient summaries — presentation","locator":"official page lines 306–319","evidence_summary":"Supports usually unilateral acute redness, moderate or severe pain, photophobia, watering, discharge, blurred vision, corneal opacity or ulcer, and contact-lens, injury, surgery, exposure, dry-eye, or immune-risk context."},{"section_id":"college-microbial-keratitis-v14-emergency","heading":"Patient summary — sight-threatening emergency and referral","locator":"official page lines 320–350","evidence_summary":"Identifies microbial keratitis as sight-threatening and supports urgent ophthalmology documentation; treatment specifics are not mapped."}]},{"source_resolves":true,"source_id":"dha-conjunctivitis-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Conjunctivitis","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/25%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Conguctivitis2024313936.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-conjunctivitis-i2-red-flags","heading":"Section 6 — red flags","locator":"pages 14–15","evidence_summary":"Lists reduced visual acuity, ciliary flush, photophobia, severe foreign-body sensation, corneal opacity, fixed pupil, severe headache with nausea, post-traumatic red eye, and immune compromise."},{"section_id":"dha-conjunctivitis-i2-diagnosis-history","heading":"Section 7 — diagnosis, history, pitfalls, and contact-lens wearers","locator":"pages 16–19","evidence_summary":"Requires history and visual review for red eye and discharge, distinguishes discharge character, asks about vision, foreign-body sensation, photophobia, trauma and contact lenses, and highlights keratitis risk in contact-lens wearers."},{"section_id":"dha-conjunctivitis-i2-management-referral","heading":"Sections 8–9 — management and referral criteria","locator":"pages 19–23","evidence_summary":"Supports clinician-led management, contact-lens hygiene or cessation discussion, response review, infection-control education, and referral for persistent symptoms, reduced acuity, photophobia, corneal opacity, painful red eye, severe headache with nausea, hyphema, trauma, or inability to open the eye; dose tables are not mapped."}]}],"evidence_links":[{"evidence_item_id":"ophth-eye-pain--dha-conjunctivitis-i2-red-flags","source_id":"dha-conjunctivitis-issue2-2024","source_section_id":"dha-conjunctivitis-i2-red-flags","direct_relationship":"Supports mapped reduced vision, photophobia, fixed pupil, headache with nausea, trauma, chemical, and severe foreign-body