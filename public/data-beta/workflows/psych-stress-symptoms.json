{"workflow_number":78,"workflow_id":"psych-stress-symptoms","title":"Stress-related symptoms","specialty":"Psychiatry / Mental Health","diagnosis":"Adjustment disorder","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"DHA assessment is directly applicable in Dubai; WHO trauma guidance requires local crisis, safeguarding, and referral pathways.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-depression-issue2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Depression","issuing_organisation":"Dubai Health Authority","official_url":"https://dha.gov.ae/uploads/032024/32%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Depression2024334819.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-depression-i2-features-assessment","heading":"Sections 5–7 — depressive features and structured assessment","locator":"pages 7–18; extracted lines 104–313","evidence_summary":"Supports low mood, loss of interest, sleep, appetite, energy, concentration, guilt or worthlessness, duration, function, previous episodes and treatment, medical and medication history, stressors, social context, comorbidity, mania or hypomania, substance use, family history, and support assessment."},{"section_id":"dha-depression-i2-risk-mental-status-investigations","heading":"Section 7 — risk, mental-status examination, and selected investigations","locator":"pages 16–20; extracted lines 245–385","evidence_summary":"Supports clinician assessment of suicide, self-harm, harm or neglect, protective and support factors, mental status, cognition, insight, substance use, medical contributors, medication history, thyroid testing, and selected blood testing when indicated."},{"section_id":"dha-depression-i2-red-flags","heading":"Section 7 — red flags","locator":"page 20; extracted lines 386–390","evidence_summary":"Lists suicidal ideation or attempt, risk of harm or neglect, moderate or severe depression, and psychotic or bipolar features as escalation concerns."},{"section_id":"dha-depression-i2-adjustment-stressor-differential","heading":"Differential diagnosis — adjustment disorder with depressed mood","locator":"pages 21–22; extracted lines 430–439","evidence_summary":"Describes depressed mood in response to an identifiable psychosocial stressor and supports documenting single, multiple, recurrent, or continuing social and occupational stressors."},{"section_id":"dha-depression-i2-management-referral","heading":"Sections 8–9 — clinician-led management, monitoring, and referral","locator":"pages 23–27; extracted lines 449–528","evidence_summary":"Supports clinician-documented supportive discussion, questions, safety planning, treatment or medication decisions, monitoring, follow-up, and referral without autonomous treatment selection or doses."}]},{"source_resolves":true,"source_id":"who-stress-related-conditions-2013","title":"Guidelines for the management of conditions specifically related to stress","issuing_organisation":"World Health Organization","official_url":"https://iris.who.int/server/api/core/bitstreams/659e3dab-1e1b-4ca4-84e0-4ce26484612f/content","jurisdiction":"International","sections":[{"section_id":"who-stress-2013-assessment-scope","heading":"Assessment before applying stress-specific recommendations","locator":"document page 18; PDF page 23","evidence_summary":"Requires full assessment of presenting mental-health problems and exclusion of physical causes before stress-specific management."},{"section_id":"who-stress-2013-acute-traumatic-stress","heading":"Acute traumatic stress symptoms in the first month after a potentially traumatic event","locator":"document pages 19–23; PDF pages 24–28","evidence_summary":"Defines acute traumatic stress through i