{"workflow_number":111,"workflow_id":"resp-asthma-followup","title":"Asthma follow-up","specialty":"Respiratory / Pulmonology","diagnosis":"Asthma follow-up documentation","research_status":"partial_source_support","research_status_label":"Partial source support","uae_applicability":"Direct for DHA-licensed telehealth fields, with NICE used as international supporting evidence requiring UAE clinician review.","uae_findings":[{"finding_type":"partial_applicability","evidence_basis":"Structured source status remains partial_exact_source_verified."}],"source_references":[{"source_resolves":true,"source_id":"dha-telehealth-asthma-v2-2024","title":"DHA Telehealth Clinical Guidelines for Virtual Management of Asthma – 38","issuing_organisation":"Dubai Health Authority","official_url":"https://www.dha.gov.ae/uploads/032024/38%20-%20DHA%20Telehealth%20Clinical%20Guidelines%20for%20Virtual%20Management%20of%20Asthma2024332757.pdf","jurisdiction":"Dubai, United Arab Emirates","sections":[{"section_id":"dha-asthma-v2-scope-applicability","heading":"2. Scope; 3. Purpose; 4. Applicability","locator":"pages 9–10","evidence_summary":"Defines DHA telehealth scope, licensed-facility applicability, and emergency and controlled-medication exclusions."},{"section_id":"dha-asthma-v2-symptoms-diagnosis","heading":"5. Clinical symptoms and 6. Diagnosis","locator":"pages 10–15","evidence_summary":"Supports wheeze, cough, breathlessness, chest tightness, variation, nocturnal or seasonal pattern, triggers, exercise and occupational context, atopy or family history, bronchodilator response, respiratory examination, peak flow, and objective confirmation."},{"section_id":"dha-asthma-v2-red-flags","heading":"7. Red Flags","locator":"pages 15–16","evidence_summary":"Supports sudden or severe breathing difficulty, cardiac or chest symptoms, cyanosis, inability to speak full sentences, confusion or agitation, stridor or audible wheeze, immobility or trauma, orthopnoea, status asthmaticus, and near-fatal asthma history as clinician-assessed prompts."},{"section_id":"dha-asthma-v2-investigations","heading":"9. Investigation","locator":"pages 18–21","evidence_summary":"Supports peak flow, pulmonary function testing, spirometry, bronchodilator reversibility, and selected clinician-led investigations."},{"section_id":"dha-asthma-v2-review-referral","heading":"11.8 Uncontrolled asthma and 12. Referral criteria","locator":"pages 24–28","evidence_summary":"Supports review of alternative or comorbid causes, adherence, inhaler technique, smoking, occupational, psychosocial and environmental factors, treatment response, device review, and clinician-led referral."}]},{"source_resolves":true,"source_id":"nice-asthma-ng245-2025","title":"Asthma: diagnosis, monitoring and chronic asthma management","issuing_organisation":"National Institute for Health and Care Excellence","official_url":"https://www.nice.org.uk/guidance/ng245/chapter/recommendations","jurisdiction":"England, United Kingdom","sections":[{"section_id":"nice-ng245-asthma-clinical-assessment","heading":"Recommendations 1.1.1–1.4.6 — clinical history, examination, objective tests, and occupational asthma","locator":"recommendations 1.1.1–1.4.6","evidence_summary":"Supports wheeze, cough, breathlessness, chest tightness, symptom variation, nocturnal or seasonal pattern, triggers, atopy and family history, occupational context, respiratory examination, peak flow, FeNO, spirometry, and objective confirmation."},{"section_id":"nice-ng245-asthma-monitoring-review","heading":"Recommendations 1.5.1–1.6.4 — monitoring asthma control and uncontrolled asthma","locator":"recommendations 1.5.1–1.6.4","evidence_summary":"Supports review of symptoms, time off work or school, reliever use, systemic steroid courses, admissions or emergency attendance, validated control questionnaires, peak flow, FeNO, adherence, inhaler technique, smoking or vaping, occupational, psychosocial, seasonal and environmental factors, and response to