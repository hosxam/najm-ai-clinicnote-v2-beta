{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ingested source document",
  "type": "object",
  "required": ["source_id", "official_url", "retrieval_status", "ingestion_status"],
  "properties": {
    "source_id": {"type": "string"},
    "original_registry_entry": {"type": "object"},
    "title": {"type": ["string", "null"]},
    "publisher": {"type": ["string", "null"]},
    "jurisdiction": {"type": ["string", "null"]},
    "official_url": {"type": "string", "format": "uri"},
    "final_resolved_url": {"type": ["string", "null"], "format": "uri"},
    "content_type": {"type": ["string", "null"]},
    "document_type": {"type": ["string", "null"]},
    "language": {"type": ["string", "null"]},
    "population": {"type": ["string", "null"]},
    "intended_setting": {"type": ["string", "null"]},
    "publication_date": {},
    "revision_date": {},
    "effective_date": {},
    "date_provenance": {"type": "array"},
    "retrieval_date": {"type": ["string", "null"]},
    "retrieval_status": {"type": "string"},
    "http_metadata": {"type": "object"},
    "page_count": {"type": ["integer", "null"]},
    "raw_content_fingerprint": {"type": ["string", "null"]},
    "normalized_content_fingerprint": {"type": ["string", "null"]},
    "extraction_method": {"type": ["string", "null"]},
    "structural_quality": {"type": ["string", "null"]},
    "access_limitations": {"type": "array"},
    "replacement_or_superseding_source": {},
    "duplicate_source_id": {},
    "ingestion_status": {"type": "string", "enum": ["ingested_complete", "ingested_with_structural_limitations", "blocked_source_access", "invalid_source_target", "superseded_source", "duplicate_source"]}
  }
}
