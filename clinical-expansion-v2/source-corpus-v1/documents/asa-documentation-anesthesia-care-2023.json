    "exact_sections": [
      {
        "section_id": "asa-documentation-care-continuum",
        "heading": "Documentation across the anesthesia care continuum",
        "locator": "official statement lines 231–233",
        "evidence_summary": "Supports accurate, complete, and legible anesthesia documentation across preanesthesia, intraoperative, and postanesthesia phases."
      },
      {
        "section_id": "asa-documentation-preanesthesia",
        "heading": "Preanesthesia documentation",
        "locator": "official statement lines 234–250",
        "evidence_summary": "Supports identity, disposition, medical, surgical and anesthetic history, medicines, allergies and reactions, fasting, advance directives, airway and cardiopulmonary examination, tests, consultations, ASA status, plan including postanesthesia and pain care, and consent."
      },
      {
        "section_id": "asa-documentation-intraoperative",
        "heading": "Intraoperative or procedural anesthesia documentation",
        "locator": "official statement lines 251–262",
        "evidence_summary": "Supports re-evaluation, equipment, medicines, staff, monitoring, techniques, positioning, lines and procedures, unusual events, fluids or blood products, output, and transfer status as recorded facts."
      },
      {
        "section_id": "asa-documentation-postanesthesia",
        "heading": "Postanesthesia documentation",
        "locator": "official statement lines 263–269",
        "evidence_summary": "Supports PACU admission and discharge records, discharge criteria, complications, postanesthesia evaluation, and documented recovery status."
      }
    ],
