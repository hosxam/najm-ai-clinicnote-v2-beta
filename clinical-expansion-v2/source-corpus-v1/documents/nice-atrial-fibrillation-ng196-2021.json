        "heading": "Recommendations 1.1.1-1.1.3 - detection, 12-lead ECG, and ambulatory ECG",
        "locator": "recommendations 1.1.1-1.1.3",
        "evidence_summary": "Supports clinician assessment of relevant symptoms, pulse, ECG, and ambulatory ECG context without automatically diagnosing atrial fibrillation."
      },
      {
        "section_id": "nice-ng196-risk-function-care-package",
        "heading": "Recommendations 1.2.1-1.4.3 - stroke and bleeding risk, cardiac function, and personalised care",
        "locator": "recommendations 1.2.1-1.4.3",
        "evidence_summary": "Supports clinician-led review of stroke and bleeding risk, comorbidities, echocardiography context, symptoms, patient preferences, information, adherence, and a documented care package."
      },
      {
        "section_id": "nice-ng196-anticoagulation-review",
        "heading": "Recommendations 1.6.1-1.6.17 and 1.11.1-1.11.2 - anticoagulation discussion and review",
        "locator": "recommendations 1.6.1-1.6.17 and 1.11.1-1.11.2",
        "evidence_summary": "Supports documenting clinician-performed benefit-risk discussion, adherence and control review, renal and bleeding context, annual reassessment, and documented decisions without generating a medicine choice or dose."
      }
