        "heading": "8. Management and Investigations",
        "locator": "page 14",
        "evidence_summary": "Describes clinician-selected microscopy, fungal culture, bacterial culture, and rare biopsy when diagnosis is uncertain or atypical."
      },
      {
        "section_id": "dha-tinea-pedis-i2-management",
        "heading": "9. Treatment",
        "locator": "pages 14–18",
        "evidence_summary": "Covers clinician-led hygiene, reinfection prevention, topical or systemic treatment choices, and reassessment; no dose-bearing content is mapped."
      }
