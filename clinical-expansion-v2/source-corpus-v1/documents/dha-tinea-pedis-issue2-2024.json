      {
        "section_id": "dha-tinea-pedis-i2-red-flags",
        "heading": "7. Red Flags and Referral Criteria",
        "locator": "pages 12–13",
        "evidence_summary": "Lists severe pain, hot red foot, diabetes, immunosuppression, nail or body spread, secondary infection, systemic illness, extensive disease, and non-response."
      },
      {
