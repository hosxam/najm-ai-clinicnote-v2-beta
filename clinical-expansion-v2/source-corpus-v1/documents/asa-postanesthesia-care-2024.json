        "heading": "Standards I–II — PACU transfer, arrival evaluation, and handover",
        "locator": "official standard, Standards I–II",
        "evidence_summary": "Supports transport with appropriate monitoring and support, arrival re-evaluation, verbal report, and documented transfer status."
      },
      {
        "section_id": "asa-postanesthesia-monitoring-record",
        "heading": "Standard III — continual evaluation and recovery record",
        "locator": "official standard, Standard III",
        "evidence_summary": "Supports documented oxygenation, ventilation, circulation, consciousness, temperature, pain or other recovery observations, and use of a recovery score where appropriate."
      },
      {
        "section_id": "asa-postanesthesia-discharge-criteria",
        "heading": "Standards IV–V — discharge responsibility and criteria",
        "locator": "official standard, Standards IV–V",
        "evidence_summary": "Supports qualified discharge responsibility and institution-approved discharge criteria as recorded decisions, not automatic clearance."
      }
