    "exact_sections": [
      {
        "section_id": "dha-dysmen-i2-scope-history",
        "heading": "2. Scope; 3. Purpose; 4. Applicability; 5.1 Virtual Clinical Assessment and Clinical History",
        "locator": "pages 10–12",
        "evidence_summary": "Defines the Dubai telehealth setting and menstrual, pain, associated symptom, functional impact, contraception, medical, surgical, and sexual history required for dysmenorrhoea assessment."
      },
      {
        "section_id": "dha-dysmen-i2-red-flags",
        "heading": "6. Red Flags and exclusion of secondary dysmenorrhoea",
        "locator": "pages 12–14",
        "evidence_summary": "Lists sudden or constant severe pain, peritonism, fever, abnormal bleeding or discharge, instability, anaemia, weight loss, infertility, dyspareunia, non-midline pain, and progressive symptoms as concern features."
      },
      {
        "section_id": "dha-dysmen-i2-management-followup",
        "heading": "8. Management — non-pharmacological measures and follow-up",
        "locator": "pages 17–19",
        "evidence_summary": "Describes lifestyle measures and follow-up after teleconsultation; medication doses were reviewed but are not mapped into the workflow."
      },
      {
        "section_id": "dha-dysmen-i2-referral",
        "heading": "9. Referral Criteria",
        "locator": "pages 19–21",
        "evidence_summary": "Defines emergency and specialist referral contexts for sudden or severe pain, peritonism, pregnancy concern, abnormal bleeding, fever or discharge, progressive symptoms, and suspected secondary pathology."
      }
    ],
