        "heading": "2. Scope; 3. Purpose; 4. Applicability",
        "locator": "pages 10–11",
        "evidence_summary": "Defines pediatric gastroenteritis use in DHA-licensed telehealth and excludes emergency and controlled-medication scenarios."
      },
      {
        "section_id": "dha-peds-gastro-v2-evaluation-red-flags",
        "heading": "6. Evaluation",
        "locator": "pages 12–13",
        "evidence_summary": "Prioritises red flags, dehydration, severe alternate illness, age, fever, bleeding, persistent vomiting, neurological abnormality, and instability."
      },
      {
        "section_id": "dha-peds-gastro-v2-diagnosis",
        "heading": "7. Diagnosis",
        "locator": "page 14",
        "evidence_summary": "Defines the acute gastroenteritis symptom pattern and limits laboratory studies to atypical or targeted presentations."
      },
      {
        "section_id": "dha-peds-gastro-v2-referral",
        "heading": "12. Referral Criteria; 13. Response to Therapy",
        "locator": "pages 25–27",
        "evidence_summary": "Lists age, fever, bleeding, persistent vomiting, dehydration, neurological, instability, caregiver, and worsening criteria for face-to-face assessment."
      },
      {
        "section_id": "dha-peds-gastro-v2-dehydration",
        "heading": "Appendix 1 — assessment of dehydration",
        "locator": "pages 29–30",
        "evidence_summary": "Lists activity, consciousness, thirst, urine output, mucous membranes, pulse, capillary refill, skin turgor, heart rate, and respiratory signs."
      },
      {
        "section_id": "dha-peds-gastro-v2-history",
        "heading": "Appendix 2 — important aspects of history",
        "locator": "pages 31–32",
        "evidence_summary": "Specifies duration, stool and emesis character, urine output, intake, fever, abdominal pain, medication, contact, and exposure history."
      }
