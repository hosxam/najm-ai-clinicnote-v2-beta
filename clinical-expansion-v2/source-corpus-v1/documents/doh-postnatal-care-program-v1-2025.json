    "exact_sections": [
      {
        "section_id": "doh-postnatal-v1-scope-schedule",
        "heading": "1. Standard Scope and postnatal check schedule",
        "locator": "pages 2–3",
        "evidence_summary": "Defines Abu Dhabi postnatal services and four checks through six weeks, with timing and mode adjusted for risk."
      },
      {
        "section_id": "doh-postnatal-v1-core-maternal",
        "heading": "3.1 Core Components — maternal physical and emotional health, education, support, and continuity",
        "locator": "pages 4–7",
        "evidence_summary": "Requires maternal physical and emotional assessment, postpartum haemorrhage and hypertensive-risk screening, feeding support, family planning discussion, continuity, and EMR documentation."
      },
      {
        "section_id": "doh-postnatal-v1-high-risk-signs",
        "heading": "Appendix 1 — medical risk indicators for mothers",
        "locator": "pages 18–19",
        "evidence_summary": "Lists thromboembolic symptoms, heavy bleeding, wound infection signs, fever, abdominal pain, wound discharge, severe headache, visual symptoms, and postpartum hypertensive complications."
      },
      {
        "section_id": "doh-postnatal-v1-visit-assessments",
        "heading": "Appendices 2 and 3 — detailed maternal postnatal and home-visit checks",
        "locator": "pages 19–22",
        "evidence_summary": "Specifies vital signs, uterine involution, lochia, wound healing, bladder and bowel function, feeding, mood, support, family planning, pelvic floor, indicated tests, and documented follow-up."
      }
    ],
