    "exact_sections": [
      {
        "section_id": "dha-neck-i2-evaluation-red-flags",
        "heading": "5. Evaluation and 6. Red Flags",
        "locator": "pages 8–9",
        "evidence_summary": "Requires red-flag identification and lists myelopathic symptoms, fever, immunosuppression, weight loss, cancer, systemic symptoms, chest symptoms, and significant trauma."
      },
      {
        "section_id": "dha-neck-i2-history-exam",
        "heading": "7. Clinical History and face-to-face examination elements",
        "locator": "pages 9–11",
        "evidence_summary": "Supports onset, duration, pain character, arm radiation, paraesthesia, activity impact, posture, movement, range of motion, palpation, neurological assessment, gait, and provocative-manoeuvre documentation."
      },
      {
        "section_id": "dha-neck-i2-investigation",
        "heading": "8. Investigation",
        "locator": "pages 12–13",
        "evidence_summary": "States that atraumatic neck pain without red flags generally needs no imaging and reserves radiography, CT, or MRI for red flags, progressive neurology, or persistent moderate-to-severe pain."
      },
      {
        "section_id": "dha-neck-i2-referral",
        "heading": "12. Referral Criteria",
        "locator": "pages 23–24",
        "evidence_summary": "Lists trauma, persistent symptoms, headache, numbness or tingling, lower-limb weakness, gait or coordination issues, bowel or bladder dysfunction, immunosuppression, weight loss, fever, and chest symptoms."
      }
    ],
