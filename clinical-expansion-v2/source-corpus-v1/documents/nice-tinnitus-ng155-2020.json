        "heading": "Recommendations 1.1.1–1.1.5 — experience, impact, support, and information",
        "locator": "lines 42–103",
        "evidence_summary": "Supports tinnitus experience, duration, concerns, noise and stress context, hearing association, sleep impact, management discussion, individual preferences, information, and questions."
      },
      {
        "section_id": "nice-tinnitus-ng155-referral",
        "heading": "Recommendations 1.2.1–1.2.7 — urgent and non-urgent referral",
        "locator": "lines 104–147",
        "evidence_summary": "Supports review of suicide risk, neurological or vestibular symptoms, sudden hearing loss, distress, objective, unilateral, asymmetric, and pulsatile tinnitus, and clinician-arranged referral."
      },
      {
        "section_id": "nice-tinnitus-ng155-impact",
        "heading": "Recommendations 1.3.1–1.3.10 — functional, sleep, and psychological impact",
        "locator": "lines 148–209",
        "evidence_summary": "Supports documentation of quality-of-life, sleep, concentration, mental-health, behavioural, and psychological impact."
      },
      {
        "section_id": "nice-tinnitus-ng155-investigations",
        "heading": "Recommendations 1.4.1–1.4.9 — audiology, tympanometry, and imaging",
        "locator": "lines 210–270",
        "evidence_summary": "Supports audiological assessment, selected tympanometry, neurological or otological context, and differentiated imaging review for pulsatile, unilateral, asymmetric, or otherwise concerning tinnitus."
      }
