        "section_id": "doh-antenatal-v1-high-risk-criteria",
        "heading": "Appendix 2 — Criteria for High-Risk Pregnancies",
        "locator": "pages 13–14",
        "evidence_summary": "Defines conditions that require additional obstetric review and preserves escalation as a clinician decision rather than an automatic workflow output."
      }
