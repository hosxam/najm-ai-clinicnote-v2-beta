{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://najm.local/schema/source-date-provenance.schema.json",
  "title": "Najm per-field source-date provenance",
  "type": "object",
  "required": [
    "sourceId",
    "fieldName",
    "dateValue",
    "provenanceStatus",
    "evidenceCategory",
    "displayedLabel",
    "exactEvidenceLocation",
    "registeredSourceReference",
    "reviewedOn",
    "verificationMethod",
    "migrationVersion"
  ],
  "properties": {
    "sourceId": { "type": "string", "minLength": 1 },
    "fieldName": { "type": "string", "minLength": 1 },
    "dateValue": { "type": "string", "minLength": 1 },
    "provenanceStatus": {
      "enum": [
        "authoritative_explicit",
        "approved_unknown",
        "weaker_metadata_only",
        "cleared_derived_or_duplicated",
        "requires_source_metadata_recheck"
      ]
    },
    "evidenceCategory": {
      "enum": [
        "explicit_publication_label",
        "explicit_effective_label",
        "explicit_revision_label",
        "explicit_service_commencement_label",
        "explicit_legal_effective_label",
        "official_document_header",
        "official_document_metadata",
        "official_service_metadata",
        "webpage_update_only",
        "access_or_review_date_only",
        "unsupported_legacy_claim",
        "unknown_on_official_source"
      ]
    },
    "displayedLabel": { "type": "string", "minLength": 1 },
    "exactEvidenceLocation": { "type": "string", "minLength": 1 },
    "registeredSourceReference": { "type": "string", "minLength": 1 },
    "sectionReference": { "type": ["string", "null"] },
    "reviewedOn": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "verificationMethod": { "const": "deterministic_registered_source_metadata_reconciliation" },
    "migrationVersion": { "const": "1.0.0" }
  },
  "additionalProperties": true
}
