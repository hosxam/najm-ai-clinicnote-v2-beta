{
  "name": "najm-ai-clinicnote-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "generate:expanded-canonical": "node scripts/generateExpandedCanonical.mjs",
    "normalize:source-registry": "node scripts/normalizeAuthoritativeSourceRegistry.mjs",
    "audit:first-pass": "node scripts/auditClinicalExpansion.mjs first-pass",
    "remediate:clinical-data": "node scripts/remediateExpandedCanonical.mjs",
    "audit:final-pass": "node scripts/auditClinicalExpansion.mjs final-pass",
    "finalize:clinical-governance": "node scripts/finalizeClinicalExpansionGovernance.mjs",
    "finalize:clinical-expansion-status": "node scripts/updateClinicalExpansionCompletion.mjs",
    "generate:clinical-data": "node scripts/generateClinicalDataFromCanonical.mjs",
    "generate:clinical-reports": "node scripts/generateClinicalExpansionReports.mjs",
    "generate:clinical-data-diff": "node scripts/generateClinicalDataDiffSummary.mjs",
    "verify:clinical-data-reproducibility": "node scripts/verifyClinicalDataReproducibility.mjs",
    "validate:expanded-schema": "node scripts/validateExpandedSchema.mjs",
