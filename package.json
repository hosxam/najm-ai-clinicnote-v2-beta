    "audit:duplicates": "node scripts/auditClinicalExpansion.mjs duplicates",
    "audit:generated-data": "node scripts/verifyClinicalDataReproducibility.mjs",
    "test:safety": "tsx scripts/testSafety.mjs",
    "test:all-workflows": "tsx scripts/testAllWorkflows.mjs",
    "test:output-safety": "tsx scripts/testOutputSafety.mjs",
