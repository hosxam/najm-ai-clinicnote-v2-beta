    "audit:workflow-risk": "node scripts/auditClinicalExpansion.mjs workflow-risk",
    "audit:contradictions": "node scripts/auditClinicalExpansion.mjs contradictions",
    "audit:medication-safety": "node scripts/auditClinicalExpansion.mjs medication-safety",
